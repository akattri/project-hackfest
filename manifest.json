{
  "manifest_version": 3,
  "name": "Hackfest Landing Page",
  "version": "1.0.0",
  "description": "A custom landing page with bookmarks, Google Todo, and Google Calendar integration.",
  "permissions": [
    "bookmarks",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://suggestqueries.google.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hackfest Extension"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "616771509884-667c0rom3r0rbgd884a5tl4khnbu9olf.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/tasks",
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  }
}